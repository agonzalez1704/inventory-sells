# Clerk — from Clerk Dashboard (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# InsForge — public (browser + server, RLS-scoped)
NEXT_PUBLIC_INSFORGE_URL=
NEXT_PUBLIC_INSFORGE_ANON_KEY=

# InsForge — admin/service key, SERVER ONLY. Never expose with NEXT_PUBLIC_.
INSFORGE_API_KEY=

# App origin (OAuth redirects, absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MCP analytics server bearer token
MCP_BEARER_TOKEN=

# Allow-listed login emails (comma-separated). Optional — defaults are hardcoded
# in lib/auth/allowlist.ts. The authoritative block is the Clerk allowlist.
ALLOWED_EMAILS=
